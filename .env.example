# ============================================================
# CRI Platform — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# A long, random secret for JWT signing and session encryption
# Generate with: openssl rand -base64 64
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=cri_db
POSTGRES_USER=cri_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Full connection string used by the backend (auto-built in docker-compose)
DATABASE_URL=postgres://cri_user:REPLACE_WITH_STRONG_DB_PASSWORD@postgres:5432/cri_db

# ── URLs ──────────────────────────────────────────────────────
# The publicly accessible URL of your frontend app
FRONTEND_URL=https://app.yourdomain.com

# Allowed CORS origin (usually same as FRONTEND_URL)
CORS_ORIGIN=https://app.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────
# Recommended: AWS SES, SendGrid, Postmark, or Mailgun
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASS=REPLACE_WITH_SMTP_PASSWORD
MAIL_FROM="CRI Platform <noreply@yourdomain.com>"

# ── Stripe ────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production
STRIPE_API_KEY=sk_live_REPLACE_WITH_STRIPE_SECRET_KEY

# Get from https://dashboard.stripe.com/webhooks after creating the webhook
# Webhook URL: https://app.yourdomain.com/api/webhook
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# Create these products in Stripe Dashboard and paste the Price IDs
# Starter: $299 one-time payment
STRIPE_PRICE_STARTER=price_REPLACE_WITH_STARTER_PRICE_ID
# Enterprise: $2,500 one-time payment
STRIPE_PRICE_ENTERPRISE=price_REPLACE_WITH_ENTERPRISE_PRICE_ID

# ── LLM API (for Enterprise report recommendations) ───────────
# Get from https://console.anthropic.com
# Uses claude-sonnet-4-20250514 (~$0.165 per report at 5k/10k tokens)
LLM_PROVIDER_API_KEY=sk-ant-REPLACE_WITH_ANTHROPIC_API_KEY

# ── MCP Server ────────────────────────────────────────────────
MCP_PORT=3001

# ── Optional: Logging ─────────────────────────────────────────
LOG_LEVEL=info
